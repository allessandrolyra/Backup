        <mxCell id="0ijsYpH7cdYQbAytV-oV-35" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. Criação de Serviço para Formulario dinamico na Azure&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1.1. Parametrização do Formulario no Banco de Dados&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1.2&amp;nbsp; Geração do formulario em PDF em DOG (Caso necessário) .&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2 Assinatura do Documento.&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.1 Assinatura Fisica.&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.1.1 Gerar PDF no DOCG&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.1.2 Disponibilizar para Download no Mobile&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.1.3 Recepção do documento assinado salvar no GCCN&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.1.4&amp;nbsp; Auteração no Fluxo CRIM para Ler o documento e fazer a Validação.&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.2 Assinatura Digital&amp;nbsp;&lt;/h1&gt;&lt;div&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.2.1 Gerar PDF no DOCG&amp;nbsp;&lt;/h1&gt;&lt;/div&gt;&lt;div&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.2.2 Enviar para Docsign&amp;nbsp;&lt;/h1&gt;&lt;/div&gt;&lt;div&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.2.3 Recepção do documento assinado salvar no GCCN&amp;nbsp;&lt;/h1&gt;&lt;/div&gt;&lt;div&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2.2.4&amp;nbsp; Auteração no Fluxo CRIM para Ler o documento e fazer a Validação.&amp;nbsp;&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;3&amp;nbsp; Criação de API para BPO&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&amp;nbsp;3.1 Recepcionar Documentos e alterações de etapas&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;3.2 Sensibilizar o CRIM para andamento da Etapa&amp;nbsp;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;3.3 Salvar o documento no GCCN&lt;/h1&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;labelBackgroundColor=#FFFFCC;" parent="1" vertex="1">
