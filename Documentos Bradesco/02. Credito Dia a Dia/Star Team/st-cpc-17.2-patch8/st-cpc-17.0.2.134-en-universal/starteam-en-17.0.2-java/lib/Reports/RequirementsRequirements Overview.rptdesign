            <property name="outputFormat">PNG</property>
            <list-property name="filter">
                <structure>
                    <property name="operator">is-not-null</property>
                    <expression name="expr" type="javascript">row["Owner"]</expression>
                    <property name="updateAggregation">true</property>
                </structure>
                <structure>
                    <property name="operator">ne</property>
                    <expression name="expr" type="javascript">BirtComp.compareString(row["Status"], "complete", true, true) || BirtComp.compareString(row["Status"], "rejected", true, true)</expression>
