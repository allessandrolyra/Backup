<HTML><HEAD>
<style>
body {font-family:Sans-Serif;}
table { min-width:1000px; font-size:10pt;  border-spacing:0; vertical-align:top; border-bottom:darkblue 1px solid; }
td { padding: 0 15px; vertical-align:top}
tr:first-child { background-color:DarkBlue !important; color:white; }
tr:nth-child(even) {background: #DDD}
.linkTable tr:nth-child(even) {background:white}
.linkTable tr:nth-child(4n) {background:#ddd}
h4 { margin-bottom:0; font-size:16px }
h3 { margin-bottom:0; font-size:18px }
.name, .num { text-align:center; }
.path {text-align:right; padding-right:0; }
.changeTable th { text-align:right; font-weight:bold; } 
</style>
<TITLE>~~ReportTitle~~</TITLE></HEAD>

<BODY BGCOLOR="#FFFFFF" LINK="#0000FF" VLINK="#FF0000" ALINK="#FF0000" TEXT="#000000">
<H2 ALIGN=CENTER>~~ReportTitle~~</H2>