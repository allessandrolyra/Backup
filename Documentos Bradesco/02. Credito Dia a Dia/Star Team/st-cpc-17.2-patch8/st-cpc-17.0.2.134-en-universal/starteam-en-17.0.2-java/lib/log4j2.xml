<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">

    <!--
        NOTE:
          Do not modify the 'rollingFile' appender. You may specify
          more/different appenders, and change the other
          listed appenders.

        NOTE:
          Use caution when specifying a path for your file appender. The
          base path is determined by 'C:\WINDOWS\system32' If you
          specify a path that does not exist, this can cause the
          StarTeam Search application to terminate abnormally.

       
        NOTE:
          Supported logging levels are: [ALL,TRACE,DEBUG,INFO,WARN,ERROR,FATAL,OFF]
          The ALL has the lowest possible rank and is intended to turn on all logging.
          The TRACE Level designates finer-grained informational events than the DEBUG.
          The DEBUG Level designates fine-grained informational events that are most useful to debug an application.
          The INFO level designates informational messages that highlight the progress of the application at coarse-grained level.
          The WARN level designates potentially harmful situations.
          The ERROR level designates error events that might still allow the application to continue running.
          The FATAL level designates very severe error events that will presumably lead the application to abort.
          The OFF has the highest possible rank and is intended to turn off logging.
    -->
<Appenders>
<RollingFile
    name="rollingFile"
    fileName="${sys:logfilename}"
    filePattern="git-starteam-connector-%d{yyyy-MM-dd HH:mm:ss}.log"
    ignoreExceptions="false"
	append="true">
    <PatternLayout>
        <Pattern>%d{MM-dd-yy HH:mm:ss} %-5p %-5.5L %-40.40c{1} - %m%n</Pattern>
    </PatternLayout>
    <Policies>
        <SizeBasedTriggeringPolicy size="50 MB" />
        
    </Policies>
     <DefaultRolloverStrategy max="20"/>
</RollingFile>
</Appenders>
<Loggers>         
  <Logger name="com.starteam" level="info" additivity="false">
      <AppenderRef ref="rollingFile"/>
    </Logger>
	
	<Logger name="com.microfocus" level="info" additivity="false">
      <AppenderRef ref="rollingFile"/>
    </Logger>

	<Logger name="com.borland.starteam.server" level="info" additivity="false">
      <AppenderRef ref="rollingFile"/>
    </Logger>

	<root level="info">
      <AppenderRef ref="rollingFile"/>
    </root>    
 </Loggers>
</log4j:configuration>