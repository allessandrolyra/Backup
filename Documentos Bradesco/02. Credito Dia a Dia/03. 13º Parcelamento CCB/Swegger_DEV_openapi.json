{
  "openapi": "3.0.1",
  "info": {
    "title": "Formatador de documentos para atencipação de IRPF e 13°",
    "description": "API formatador para dados da Template IRPF e 13°. Mod.: 4840-1326E",
    "version": "1.0.0"
  },
  "externalDocs": {
    "description": "Bradescode Documentation",
    "url": "https://confluence.bradesco.com.br:8443/pages/viewpage.action?pageId=244976149"
  },
  "servers": [
    {
      "url": "/v1/formatador/ccb"
    }
  ],
  "tags": [
    {
      "name": "infra",
      "description": "cloud"
    },
    {
      "name": "tipo-api",
      "description": "interna"
    },
    {
      "name": "asset",
      "description": "antecipacao-ir-decter"
    }
  ],
  "paths": {
    "/irpf": {
      "post": {
        "tags": [
          "Formatador CCB"
        ],
        "summary": "Endpoint responsável por receber os dados da CCB, formatar e devolver a CCB em base64",
        "description": "Recebe dados básicos para geração da CCB, faz demais requisições e obtenções de dados e devolve a CCB preenchida, de acordo com o tipo do documento",
        "operationId": "montaDadosCCBIrpf",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DadosCcbRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "CCB gerada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseFormatadorCcbDTO"
                }
              }
            }
          },
          "400": {
            "description": "Falha ao validar requisição",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          },
          "403": {
            "description": "Falha ao validar requisição",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          },
          "429": {
            "description": "Falha ao validar requisição",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          }
        }
      }
    },
    "/decter": {
      "post": {
        "tags": [
          "Formatador CCB"
        ],
        "summary": "Endpoint responsável por receber os dados da CCB, formatar e devolver a CCB em base64",
        "description": "Recebe dados básicos para geração da CCB, faz demais requisições e obtenções de dados e devolve a CCB preenchida, de acordo com o tipo do documento",
        "operationId": "montaDadosCCBDecter",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DadosCcbRequestDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "CCB gerada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseFormatadorCcbDTO"
                }
              }
            }
          },
          "400": {
            "description": "Falha ao validar requisição",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          },
          "403": {
            "description": "Falha ao validar requisição",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          },
          "429": {
            "description": "Falha ao validar requisição",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErroResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DadosCcbRequestDTO": {
        "type": "object",
        "properties": {
          "autDebitosVencidos": {
            "type": "boolean"
          },
          "autDebitosLimiteCredito": {
            "type": "boolean"
          },
          "nroControleCotacaoSeguro": {
            "type": "string"
          },
          "numSimulacaoContrato": {
            "type": "string"
          },
          "titularidadeOrigem": {
            "type": "string"
          },
          "flagSeguro": {
            "type": "boolean"
          },
          "tipoDocumento": {
            "type": "string",
            "enum": [
              "PREVIA",
              "FORMALIZACAO"
            ]
          },
          "canal": {
            "type": "string",
            "enum": [
              "MOBILE"
            ]
          },
          "produtoOperacional": {
            "type": "integer",
            "format": "int32"
          },
          "dadosConta": {
            "$ref": "#/components/schemas/DadosContaDTO"
          }
        }
      },
      "DadosContaDTO": {
        "type": "object",
        "properties": {
          "agLogada": {
            "type": "string"
          },
          "ccLogada": {
            "type": "string"
          },
          "cSalario": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DadosContasSalarioDTO"
            }
          }
        }
      },
      "DadosContasSalarioDTO": {
        "type": "object",
        "properties": {
          "agencia": {
            "type": "string"
          },
          "conta": {
            "type": "string"
          }
        }
      },
      "ResponseFormatadorCcbDTO": {
        "type": "object",
        "properties": {
          "conteudo": {
            "type": "string"
          }
        }
      },
      "ApiErroResponse": {
        "type": "object",
        "properties": {
          "apierro": {
            "type": "object",
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "status": {
                "type": "string",
                "enum": [
                  "100 CONTINUE",
                  "101 SWITCHING_PROTOCOLS",
                  "102 PROCESSING",
                  "103 EARLY_HINTS",
                  "103 CHECKPOINT",
                  "200 OK",
                  "201 CREATED",
                  "202 ACCEPTED",
                  "203 NON_AUTHORITATIVE_INFORMATION",
                  "204 NO_CONTENT",
                  "205 RESET_CONTENT",
                  "206 PARTIAL_CONTENT",
                  "207 MULTI_STATUS",
                  "208 ALREADY_REPORTED",
                  "226 IM_USED",
                  "300 MULTIPLE_CHOICES",
                  "301 MOVED_PERMANENTLY",
                  "302 FOUND",
                  "302 MOVED_TEMPORARILY",
                  "303 SEE_OTHER",
                  "304 NOT_MODIFIED",
                  "305 USE_PROXY",
                  "307 TEMPORARY_REDIRECT",
                  "308 PERMANENT_REDIRECT",
                  "400 BAD_REQUEST",
                  "401 UNAUTHORIZED",
                  "402 PAYMENT_REQUIRED",
                  "403 FORBIDDEN",
                  "404 NOT_FOUND",
                  "405 METHOD_NOT_ALLOWED",
                  "406 NOT_ACCEPTABLE",
                  "407 PROXY_AUTHENTICATION_REQUIRED",
                  "408 REQUEST_TIMEOUT",
                  "409 CONFLICT",
                  "410 GONE",
                  "411 LENGTH_REQUIRED",
                  "412 PRECONDITION_FAILED",
                  "413 PAYLOAD_TOO_LARGE",
                  "413 REQUEST_ENTITY_TOO_LARGE",
                  "414 URI_TOO_LONG",
                  "414 REQUEST_URI_TOO_LONG",
                  "415 UNSUPPORTED_MEDIA_TYPE",
                  "416 REQUESTED_RANGE_NOT_SATISFIABLE",
                  "417 EXPECTATION_FAILED",
                  "418 I_AM_A_TEAPOT",
                  "419 INSUFFICIENT_SPACE_ON_RESOURCE",
                  "420 METHOD_FAILURE",
                  "421 DESTINATION_LOCKED",
                  "422 UNPROCESSABLE_ENTITY",
                  "423 LOCKED",
                  "424 FAILED_DEPENDENCY",
                  "425 TOO_EARLY",
                  "426 UPGRADE_REQUIRED",
                  "428 PRECONDITION_REQUIRED",
                  "429 TOO_MANY_REQUESTS",
                  "431 REQUEST_HEADER_FIELDS_TOO_LARGE",
                  "451 UNAVAILABLE_FOR_LEGAL_REASONS",
                  "500 INTERNAL_SERVER_ERROR",
                  "501 NOT_IMPLEMENTED",
                  "502 BAD_GATEWAY",
                  "503 SERVICE_UNAVAILABLE",
                  "504 GATEWAY_TIMEOUT",
                  "505 HTTP_VERSION_NOT_SUPPORTED",
                  "506 VARIANT_ALSO_NEGOTIATES",
                  "507 INSUFFICIENT_STORAGE",
                  "508 LOOP_DETECTED",
                  "509 BANDWIDTH_LIMIT_EXCEEDED",
                  "510 NOT_EXTENDED",
                  "511 NETWORK_AUTHENTICATION_REQUIRED"
                ]
              },
              "codigoErro": {
                "type": "integer",
                "format": "int32"
              },
              "mensagem": {
                "type": "string"
              },
              "mensagemDetalhada": {
                "type": "string"
              },
              "subErros": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ApiSubErroResponse"
                }
              }
            }
          }
        }
      },
      "ApiSubErroResponse": {
        "type": "object"
      }
    }
  }
}